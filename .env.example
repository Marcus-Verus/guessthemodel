# --- Live AI-fakes generation (optional) ---
# The game falls back to the built-in house deck if neither key is set.
# Preferred: route through OpenRouter to use your OpenRouter credits.
OPENROUTER_API_KEY=your-openrouter-key
# Any model slug you have credits for (e.g. anthropic/claude-sonnet-4.5,
# openai/gpt-4o-mini, google/gemini-flash-1.5). Defaults to Claude via OpenRouter.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Fallback: call Anthropic directly (used only if OPENROUTER_API_KEY is unset).
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Email signups + ops dashboard (optional) ---
# Server-only Supabase access (service-role key — never exposed to the browser).
# Run supabase/migrations/001_duped.sql on your project first.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Secret to open /ops/dashboard?key=...  (route 404s without the right key).
ADMIN_SECRET=choose-a-long-random-string
